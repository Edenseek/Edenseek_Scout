OPENAI_API_KEY=your_api_key_here
SCOUT_USERNAME=derek
SCOUT_PASSWORD=your_password_here

# Phase 1 Dataset Auditor input directory (read-only).
# Defaults to the committed fixtures if unset.
SCOUT_DATASET_DIR=fixtures/dataset/society_of_killers/issue_1

# Phase D2 Automated Daily Digest.
# The dataset-audit path makes no LLM calls, so daily runs are free/safe.
# Deploy with a single worker (in-process scheduler; cross-process is unsafe).
SCOUT_AUDIT_ENABLED=true
SCOUT_AUDIT_HOUR=8
SCOUT_AUDIT_MINUTE=0
SCOUT_AUDIT_TZ=America/New_York

# Legacy OpenAI strategic-report job (pre-pivot). Kept but disabled by default.
SCOUT_LEGACY_JOB_ENABLED=false
